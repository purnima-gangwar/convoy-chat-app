generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  avatar     String?
  bio        String?
  isOnline   Boolean  @default(false)
  lastSeen   DateTime?
  createdAt  DateTime @default(now())
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  text       String
  isDelivered  Boolean  @default(false)
  isSeen       Boolean  @default(false)
  createdAt  DateTime @default(now())
}